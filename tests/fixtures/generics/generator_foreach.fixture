// expect: doWork(
---
<?php
class Task {
    public function doWork(): void {}
}
class Foobar {
    /**
     * @return Generator<string, Task>
     */
    public function gen(): Generator
    {
    }
}
$foo = new Foobar();
foreach ($foo->gen() as $bar) {
    $bar-><>
}