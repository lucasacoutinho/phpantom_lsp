// test: PHP 8.4 property hook get accessor resolves property type
// feature: completion
// Adapted from phpactor property-hooks/property-get.test
// expect: strlen(
---
<?php

class StringWrapper {
    public function strlen(): int {}
}

class Some
{
    public StringWrapper $foobar {
        get {
            return new StringWrapper();
        }
    }
}

$s = new Some();
$s->foobar-><>