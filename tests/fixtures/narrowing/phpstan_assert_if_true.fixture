<?php

class User {
    public function getName(): string {}
}

class Validator {
    /**
     * @phpstan-assert-if-true User $value
     */
    public static function isUser(mixed $value): bool {}
}

function test(mixed $input): void {
    if (Validator::isUser($input)) {
        $input-><>
    }
}