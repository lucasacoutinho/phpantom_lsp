// test: @var docblock overrides collection item type in foreach
// feature: completion
// Adapted from phpactor foreach/with_docblock.test
// expect: hello(
---
<?php

class Foobar
{
    public function hello(): void {}
}

$collection = [];

/** @var Foobar $foobar */
foreach ($collection as $foobar) {
    $foobar-><>
}